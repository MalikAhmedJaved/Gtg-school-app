{
  "expo": {
    "name": "My Gtg",
    "slug": "glory-to-god-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon-square.png",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1A5276"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you share them."
        }
      ],
      "@react-native-community/datetimepicker",
      "./plugins/disable-png-crunch"
    ],
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.glorytogod.ppec",
      "icon": "./assets/icon-square.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A5276"
      },
      "package": "com.glorytogod.ppec",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "a8ce6163-51d6-43e9-84a5-fe1a88d1e855"
      }
    },
    "owner": "malik1460"
  }
}

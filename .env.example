# ========== Mobile App Environment ==========
# Copy this file to .env and fill in your values.
# The Glory to God PPEC backend is not yet deployed — set this once it's live.

# Local backend (for emulator/simulator):
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# For native device testing against a local backend, use your LAN IP:
# EXPO_PUBLIC_API_URL=http://192.168.1.100:3000/api

# Production backend (fill in when deployed):
# EXPO_PUBLIC_API_URL=https://api.glorytogodmiami.com/api
